# Connection string Postgres (Prisma Postgres / Vercel Postgres / Neon / Supabase)
DATABASE_URL="postgresql://user:password@host:5432/dbname"
JWT_SECRET="ganti-dengan-secret-anda"

# Google OAuth (Login dengan Google)
# Buat kredensial di https://console.cloud.google.com/apis/credentials
# Authorized redirect URI harus persis sama dengan GOOGLE_REDIRECT_URI di bawah.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://127.0.0.1:8000/auth/google/callback"
